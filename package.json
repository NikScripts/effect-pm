{
  "name": "@nikscripts/effect-pm",
  "version": "0.4.0-beta.1",
  "description": "Manage long-running Effect processes with runtime control. Queue resource-heavy operations with configurable throttling and priorities. Schedule recurring tasks with cron. Check status, start/stop processes, and view metrics through a CLI while your application runs.",
  "keywords": [
    "effect",
    "process-manager",
    "cron",
    "scheduler",
    "queue",
    "priority-queue",
    "task-scheduler",
    "job-queue",
    "orchestration",
    "typescript"
  ],
  "author": "Nikolas Stow",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nikscripts/effect-pm.git"
  },
  "bugs": {
    "url": "https://github.com/nikscripts/effect-pm/issues"
  },
  "homepage": "https://github.com/nikscripts/effect-pm#readme",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build && npm run type-check",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run build && changeset publish",
    "example": "tsx examples/example.ts",
    "cli": "tsx examples/cli.ts"
  },
  "dependencies": {
    "@effect/cli": "^0.71.0",
    "@effect/platform": "^0.92.1",
    "@effect/platform-node": "^0.98.3",
    "@effect/printer": "^0.46.0",
    "@effect/printer-ansi": "^0.46.0",
    "@effect/typeclass": "^0.37.0",
    "cli-table3": "^0.6.5",
    "pretty-ms": "^9.1.0"
  },
  "peerDependencies": {
    "effect": "^3.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@types/node": "^20.19.20",
    "effect": "^3.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
